# ─── PostgreSQL ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://goalong:goalong_secret@localhost:5432/goalong_db

# ─── MongoDB ──────────────────────────────────
MONGODB_URL=mongodb://goalong:goalong_secret@localhost:27017/goalong_chat?authSource=admin
MONGODB_DB_NAME=goalong_chat

# ─── Supabase ─────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ─── App ──────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ─── FCM (Push Notifications) ─────────────────
FCM_SERVER_KEY=your-fcm-server-key-here

# ─── OSRM ─────────────────────────────────────
OSRM_BASE_URL=http://localhost:5000

# ─── Fare Engine Defaults ─────────────────────
FUEL_PRICE_PER_LITRE=103.0
DEFAULT_MILEAGE_KM_PER_LITRE=15.0
PLATFORM_MARGIN_PERCENT=10.0

# ─── Referral ─────────────────────────────────
REFERRAL_REWARD_AMOUNT=50.0

# ─── Toll Detection ───────────────────────────
TOLL_DETECTION_RADIUS_METERS=100.0
